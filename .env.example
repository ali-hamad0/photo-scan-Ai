# Copy this file to .env and fill in the values
# cp .env.example .env

# ── Database ───────────────────────────────────────
DB_ROOT_PASSWORD=strongrootpassword
DB_USER=pathoscan
DB_PASSWORD=stronguserpassword

# ── Security ───────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# ── CORS (comma-separated allowed origins) ─────────
# For local: http://localhost
# For production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost

# ── Token expiry ───────────────────────────────────
TOKEN_EXPIRE_HOURS=24

# ── Groq AI (LLM for RAG chat) ─────────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
# Available models: llama-3.3-70b-versatile, llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# ── Rate limits ────────────────────────────────────
RATE_LIMIT_ANALYZE=10/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_CHAT=20/minute
